<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login | Afno Ghar Backend</title>
</head>
<body>
  <h1>Login</h1>
  <form action="/api/auth/login" method="POST">
    <label>Email</label>
    <input type="email" name="email" required />
    <label>Password</label>
    <input type="password" name="password" required />
    <button type="submit">Login</button>
  </form>
  <p><a href="/api/auth/signup">Create a new account</a></p>
</body>
</html>
